    <item>
      <title>Monte Carlo Simulation</title>
      <link>//localhost:1313/projects/monte-carlo/</link>
      <pubDate>Tue, 31 Mar 2026 00:00:00 +0000</pubDate>
      <guid>//localhost:1313/projects/monte-carlo/</guid>
      <description>&lt;p&gt;This project demonstrates a high-performance Monte Carlo simulation for Geometric Brownian Motion, implemented in C++ and compiled to WebAssembly.&lt;/p&gt;&#xA;&lt;div class=&#34;mc-widget&#34;&gt;&#xA;    &#xA;    &lt;div style=&#34;display: flex; gap: 15px; align-items: flex-end; margin-bottom: 30px; flex-wrap: wrap;&#34;&gt;&#xA;        &lt;div style=&#34;flex: 1; min-width: 120px;&#34;&gt;&#xA;            &lt;label style=&#34;display: block; font-family: &#39;JetBrains Mono&#39;, monospace; font-size: 0.65rem; color: var(--muted); margin-bottom: 8px;&#34;&gt;RATE r (%)&lt;/label&gt;&#xA;            &lt;input type=&#34;number&#34; id=&#34;rateInput&#34; value=&#34;3&#34; min=&#34;0&#34; max=&#34;100&#34; step=&#34;0.1&#34; &#xA;                   style=&#34;width: 100%; padding: 8px; border: 1px solid var(--border); border-radius: 4px; font-family: &#39;JetBrains Mono&#39;, monospace;&#34;&gt;&#xA;        &lt;/div&gt;&#xA;        &lt;div style=&#34;flex: 1; min-width: 120px;&#34;&gt;&#xA;            &lt;label style=&#34;display: block; font-family: &#39;JetBrains Mono&#39;, monospace; font-size: 0.65rem; color: var(--muted); margin-bottom: 8px;&#34;&gt;VOLATILITY σ (%)&lt;/label&gt;&#xA;            &lt;input type=&#34;number&#34; id=&#34;volInput&#34; value=&#34;20&#34; min=&#34;1&#34; max=&#34;500&#34; step=&#34;0.5&#34; &#xA;                   style=&#34;width: 100%; padding: 8px; border: 1px solid var(--border); border-radius: 4px; font-family: &#39;JetBrains Mono&#39;, monospace;&#34;&gt;&#xA;        &lt;/div&gt;&#xA;        &lt;div style=&#34;flex: 1; min-width: 120px;&#34;&gt;&#xA;            &lt;label style=&#34;display: block; font-family: &#39;JetBrains Mono&#39;, monospace; font-size: 0.65rem; color: var(--muted); margin-bottom: 8px;&#34;&gt;SIMS (PATHS)&lt;/label&gt;&#xA;            &lt;input type=&#34;number&#34; id=&#34;pathInput&#34; value=&#34;250&#34; min=&#34;1&#34; max=&#34;5000&#34; &#xA;                   style=&#34;width: 100%; padding: 8px; border: 1px solid var(--border); border-radius: 4px; font-family: &#39;JetBrains Mono&#39;, monospace;&#34;&gt;&#xA;        &lt;/div&gt;&#xA;        &lt;div style=&#34;flex: 0;&#34;&gt;&#xA;            &lt;button id=&#34;calcButton&#34; &#xA;                    style=&#34;padding: 9px 24px; background: var(--accent); color: #fff; border: none; border-radius: 4px; font-family: &#39;Inter&#39;, sans-serif; font-weight: 600; cursor: pointer; height: 40px;&#34;&gt;&#xA;                Calculate&#xA;            &lt;/button&gt;&#xA;        &lt;/div&gt;&#xA;    &lt;/div&gt;&#xA;&#xA;    &#xA;    &lt;div style=&#34;display: grid; grid-template-columns: 3fr 1fr; gap: 20px; margin-bottom: 20px;&#34;&gt;&#xA;        &lt;div style=&#34;background: #fff; border: 1px solid var(--border); border-radius: 8px; padding: 20px; display: flex; flex-direction: column;&#34;&gt;&#xA;            &lt;div style=&#34;font-family: &#39;JetBrains Mono&#39;, monospace; font-size: 0.7rem; color: var(--muted); margin-bottom: 15px;&#34;&gt;PRICE_EVOLUTION_PATHS&lt;/div&gt;&#xA;            &lt;div style=&#34;flex-grow: 1; position: relative; height: 350px;&#34;&gt;&#xA;                &lt;canvas id=&#34;mcChart&#34;&gt;&lt;/canvas&gt;&#xA;            &lt;/div&gt;&#xA;        &lt;/div&gt;&#xA;        &lt;div style=&#34;background: #fff; border: 1px solid var(--border); border-radius: 8px; padding: 20px; display: flex; flex-direction: column;&#34;&gt;&#xA;            &lt;div style=&#34;font-family: &#39;JetBrains Mono&#39;, monospace; font-size: 0.7rem; color: var(--muted); margin-bottom: 15px;&#34;&gt;DISTRIBUTION&lt;/div&gt;&#xA;            &lt;div style=&#34;flex-grow: 1; position: relative; height: 350px;&#34;&gt;&#xA;                &lt;canvas id=&#34;distChart&#34;&gt;&lt;/canvas&gt;&#xA;            &lt;/div&gt;&#xA;        &lt;/div&gt;&#xA;    &lt;/div&gt;&#xA;&#xA;    &#xA;    &lt;div style=&#34;display: grid; grid-template-columns: repeat(6, 1fr); gap: 10px; margin-top: 30px;&#34; id=&#34;greeks-container&#34;&gt;&#xA;        &lt;div style=&#34;padding: 10px; border: 1px solid var(--border); border-radius: 8px; text-align: center;&#34;&gt;&#xA;            &lt;div style=&#34;font-family: &#39;JetBrains Mono&#39;, monospace; font-size: 0.65rem; color: var(--muted); margin-bottom: 4px;&#34;&gt;DELTA&lt;/div&gt;&#xA;            &lt;div style=&#34;font-family: &#39;JetBrains Mono&#39;, monospace; font-weight: 600; font-size: 0.9rem;&#34; id=&#34;delta-value&#34;&gt;0.0000&lt;/div&gt;&#xA;        &lt;/div&gt;&#xA;        &lt;div style=&#34;padding: 10px; border: 1px solid var(--border); border-radius: 8px; text-align: center;&#34;&gt;&#xA;            &lt;div style=&#34;font-family: &#39;JetBrains Mono&#39;, monospace; font-size: 0.65rem; color: var(--muted); margin-bottom: 4px;&#34;&gt;GAMMA&lt;/div&gt;&#xA;            &lt;div style=&#34;font-family: &#39;JetBrains Mono&#39;, monospace; font-weight: 600; font-size: 0.9rem;&#34; id=&#34;gamma-value&#34;&gt;0.0000&lt;/div&gt;&#xA;        &lt;/div&gt;&#xA;        &lt;div style=&#34;padding: 10px; border: 1px solid var(--border); border-radius: 8px; text-align: center;&#34;&gt;&#xA;            &lt;div style=&#34;font-family: &#39;JetBrains Mono&#39;, monospace; font-size: 0.65rem; color: var(--muted); margin-bottom: 4px;&#34;&gt;VEGA&lt;/div&gt;&#xA;            &lt;div style=&#34;font-family: &#39;JetBrains Mono&#39;, monospace; font-weight: 600; font-size: 0.9rem;&#34; id=&#34;vega-value&#34;&gt;0.0000&lt;/div&gt;&#xA;        &lt;/div&gt;&#xA;        &lt;div style=&#34;padding: 10px; border: 1px solid var(--border); border-radius: 8px; text-align: center;&#34;&gt;&#xA;            &lt;div style=&#34;font-family: &#39;JetBrains Mono&#39;, monospace; font-size: 0.65rem; color: var(--muted); margin-bottom: 4px;&#34;&gt;THETA&lt;/div&gt;&#xA;            &lt;div style=&#34;font-family: &#39;JetBrains Mono&#39;, monospace; font-weight: 600; font-size: 0.9rem;&#34; id=&#34;theta-value&#34;&gt;0.0000&lt;/div&gt;&#xA;        &lt;/div&gt;&#xA;        &lt;div style=&#34;padding: 10px; border: 1px solid var(--border); border-radius: 8px; text-align: center;&#34;&gt;&#xA;            &lt;div style=&#34;font-family: &#39;JetBrains Mono&#39;, monospace; font-size: 0.65rem; color: var(--muted); margin-bottom: 4px;&#34;&gt;RHO&lt;/div&gt;&#xA;            &lt;div style=&#34;font-family: &#39;JetBrains Mono&#39;, monospace; font-weight: 600; font-size: 0.9rem;&#34; id=&#34;rho-value&#34;&gt;0.0000&lt;/div&gt;&#xA;        &lt;/div&gt;&#xA;        &lt;div style=&#34;padding: 10px; border: 1px solid var(--border); border-radius: 8px; text-align: center; background: #f8fafc;&#34;&gt;&#xA;            &lt;div style=&#34;font-family: &#39;JetBrains Mono&#39;, monospace; font-size: 0.65rem; color: var(--accent); margin-bottom: 4px;&#34;&gt;PROB. PROFIT&lt;/div&gt;&#xA;            &lt;div style=&#34;font-family: &#39;JetBrains Mono&#39;, monospace; font-weight: 700; font-size: 0.9rem; color: var(--accent);&#34; id=&#34;pop-value&#34;&gt;0.0%&lt;/div&gt;&#xA;        &lt;/div&gt;&#xA;    &lt;/div&gt;&#xA;&#xA;    &#xA;    &lt;div style=&#34;margin-top: 50px; border-top: 1px solid var(--border); padding-top: 30px;&#34;&gt;&#xA;        &lt;h3 style=&#34;font-family: &#39;JetBrains Mono&#39;, monospace; font-size: 0.9rem; color: var(--accent); margin-bottom: 25px;&#34;&gt;OPTION_PRICE_SURFACE_HEATMAP&lt;/h3&gt;&#xA;        &#xA;        &lt;div style=&#34;display: grid; grid-template-columns: repeat(auto-fit, minmax(130px, 1fr)); gap: 15px; margin-bottom: 25px; align-items: flex-end;&#34;&gt;&#xA;            &lt;div&gt;&#xA;                &lt;label style=&#34;display: block; font-family: &#39;JetBrains Mono&#39;, monospace; font-size: 0.65rem; color: var(--muted); margin-bottom: 6px;&#34;&gt;OPTION TYPE&lt;/label&gt;&#xA;                &lt;select id=&#34;optType&#34; style=&#34;width: 100%; padding: 6px; border: 1px solid var(--border); border-radius: 4px; font-size: 0.8rem; background: #fff;&#34;&gt;&#xA;                    &lt;option value=&#34;european&#34;&gt;European&lt;/option&gt;&#xA;                    &lt;option value=&#34;asian&#34;&gt;Asian&lt;/option&gt;&#xA;                &lt;/select&gt;&#xA;            &lt;/div&gt;&#xA;            &lt;div&gt;&#xA;                &lt;label style=&#34;display: block; font-family: &#39;JetBrains Mono&#39;, monospace; font-size: 0.65rem; color: var(--muted); margin-bottom: 6px;&#34;&gt;METRIC (Z-AXIS)&lt;/label&gt;&#xA;                &lt;select id=&#34;metricType&#34; style=&#34;width: 100%; padding: 6px; border: 1px solid var(--border); border-radius: 4px; font-size: 0.8rem; background: #fff;&#34;&gt;&#xA;                    &lt;option value=&#34;price&#34;&gt;Price&lt;/option&gt;&#xA;                    &lt;option value=&#34;delta&#34;&gt;Delta (Δ)&lt;/option&gt;&#xA;                    &lt;option value=&#34;gamma&#34;&gt;Gamma (Γ)&lt;/option&gt;&#xA;                    &lt;option value=&#34;vega&#34;&gt;Vega (ν)&lt;/option&gt;&#xA;                    &lt;option value=&#34;theta&#34;&gt;Theta (Θ)&lt;/option&gt;&#xA;                    &lt;option value=&#34;rho&#34;&gt;Rho (ρ)&lt;/option&gt;&#xA;                    &lt;option value=&#34;prob_profit&#34;&gt;Prob. Profit&lt;/option&gt;&#xA;                    &lt;option value=&#34;std_error&#34;&gt;Std Error&lt;/option&gt;&#xA;                &lt;/select&gt;&#xA;            &lt;/div&gt;&#xA;            &lt;div&gt;&#xA;                &lt;label style=&#34;display: block; font-family: &#39;JetBrains Mono&#39;, monospace; font-size: 0.65rem; color: var(--muted); margin-bottom: 6px;&#34;&gt;RATE r (%)&lt;/label&gt;&#xA;                &lt;input type=&#34;number&#34; id=&#34;heatRate&#34; value=&#34;3&#34; min=&#34;0&#34; max=&#34;100&#34; step=&#34;0.1&#34; &#xA;                       style=&#34;width: 100%; padding: 6px; border: 1px solid var(--border); border-radius: 4px; font-size: 0.8rem;&#34;&gt;&#xA;            &lt;/div&gt;&#xA;            &lt;div&gt;&#xA;                &lt;label style=&#34;display: block; font-family: &#39;JetBrains Mono&#39;, monospace; font-size: 0.65rem; color: var(--muted); margin-bottom: 6px;&#34;&gt;SPOT_MIN / MAX&lt;/label&gt;&#xA;                &lt;div style=&#34;display: flex; gap: 5px;&#34;&gt;&#xA;                    &lt;input type=&#34;number&#34; id=&#34;spotMin&#34; value=&#34;80&#34; style=&#34;width: 50%; padding: 6px; border: 1px solid var(--border); border-radius: 4px; font-size: 0.8rem;&#34;&gt;&#xA;                    &lt;input type=&#34;number&#34; id=&#34;spotMax&#34; value=&#34;120&#34; style=&#34;width: 50%; padding: 6px; border: 1px solid var(--border); border-radius: 4px; font-size: 0.8rem;&#34;&gt;&#xA;                &lt;/div&gt;&#xA;            &lt;/div&gt;&#xA;            &lt;div&gt;&#xA;                &lt;label style=&#34;display: block; font-family: &#39;JetBrains Mono&#39;, monospace; font-size: 0.65rem; color: var(--muted); margin-bottom: 6px;&#34;&gt;VOL_MIN / MAX (%)&lt;/label&gt;&#xA;                &lt;div style=&#34;display: flex; gap: 5px;&#34;&gt;&#xA;                    &lt;input type=&#34;number&#34; id=&#34;vMin&#34; value=&#34;10&#34; style=&#34;width: 50%; padding: 6px; border: 1px solid var(--border); border-radius: 4px; font-size: 0.8rem;&#34;&gt;&#xA;                    &lt;input type=&#34;number&#34; id=&#34;vMax&#34; value=&#34;50&#34; style=&#34;width: 50%; padding: 6px; border: 1px solid var(--border); border-radius: 4px; font-size: 0.8rem;&#34;&gt;&#xA;                &lt;/div&gt;&#xA;            &lt;/div&gt;&#xA;            &lt;div&gt;&#xA;                &lt;label style=&#34;display: block; font-family: &#39;JetBrains Mono&#39;, monospace; font-size: 0.65rem; color: var(--muted); margin-bottom: 6px;&#34;&gt;RESOLUTION&lt;/label&gt;&#xA;                &lt;input type=&#34;number&#34; id=&#34;steps&#34; value=&#34;20&#34; min=&#34;5&#34; max=&#34;50&#34; style=&#34;width: 100%; padding: 6px; border: 1px solid var(--border); border-radius: 4px; font-size: 0.8rem;&#34;&gt;&#xA;            &lt;/div&gt;&#xA;            &lt;div&gt;&#xA;                &lt;label style=&#34;display: block; font-family: &#39;JetBrains Mono&#39;, monospace; font-size: 0.65rem; color: var(--muted); margin-bottom: 6px;&#34;&gt;SIMS/CELL&lt;/label&gt;&#xA;                &lt;input type=&#34;number&#34; id=&#34;heatSims&#34; value=&#34;1000&#34; min=&#34;100&#34; max=&#34;100000&#34; step=&#34;100&#34; style=&#34;width: 100%; padding: 6px; border: 1px solid var(--border); border-radius: 4px; font-size: 0.8rem;&#34;&gt;&#xA;            &lt;/div&gt;&#xA;            &lt;div&gt;&#xA;                &lt;button id=&#34;heatButton&#34; style=&#34;width: 100%; padding: 8px; background: var(--accent); color: #fff; border: none; border-radius: 4px; font-family: &#39;Inter&#39;, sans-serif; font-weight: 600; cursor: pointer; height: 35px;&#34;&gt;&#xA;                    Generate&#xA;                &lt;/button&gt;&#xA;            &lt;/div&gt;&#xA;        &lt;/div&gt;&#xA;&#xA;        &lt;div style=&#34;position: relative; background: #fff; border: 1px solid var(--border); border-radius: 8px; padding: 20px; text-align: center;&#34;&gt;&#xA;            &lt;canvas id=&#34;heatChart&#34; style=&#34;max-width: 100%; height: 400px;&#34;&gt;&lt;/canvas&gt;&#xA;        &lt;/div&gt;&#xA;    &lt;/div&gt;&#xA;&lt;/div&gt;&#xA;&#xA;&lt;script src=&#34;https://cdn.jsdelivr.net/npm/chart.js&#34;&gt;&lt;/script&gt;&#xA;&lt;script src=&#34;//localhost:1313/js/mc_engine.js&#34;&gt;&lt;/script&gt;&#xA;&#xA;&lt;script&gt;&#xA;    let mcModule;&#xA;    let chart;&#xA;    let distChart;&#xA;&#xA;    const chartOptions = {&#xA;        responsive: true,&#xA;        maintainAspectRatio: false,&#xA;        animation: false,&#xA;        plugins: { legend: { display: false } }&#xA;    };&#xA;&#xA;    const yAxisConfig = {&#xA;        type: &#39;linear&#39;,&#xA;        grid: { color: &#39;#f5f5f5&#39;, drawBorder: false },&#xA;        ticks: { color: &#39;#999&#39;, font: { family: &#39;JetBrains Mono&#39;, size: 9 } }&#xA;    };&#xA;&#xA;    const ctx = document.getElementById(&#39;mcChart&#39;).getContext(&#39;2d&#39;);&#xA;    chart = new Chart(ctx, {&#xA;        type: &#39;line&#39;,&#xA;        data: { labels: Array.from({length: 253}, (_, i) =&gt; i), datasets: [] },&#xA;        options: {&#xA;            ...chartOptions,&#xA;            elements: { point: { radius: 0 }, line: { tension: 0.1 } },&#xA;            scales: {&#xA;                y: { ...yAxisConfig, title: { display: true, text: &#39;Price ($)&#39;, font: { size: 10 } } },&#xA;                x: { &#xA;                    grid: { color: &#39;#f5f5f5&#39;, drawBorder: false },&#xA;                    ticks: { color: &#39;#999&#39;, font: { family: &#39;JetBrains Mono&#39;, size: 9 } },&#xA;                    title: { display: true, text: &#39;Time (T=1.0)&#39;, font: { size: 10 } }&#xA;                }&#xA;            }&#xA;        }&#xA;    });&#xA;&#xA;    const dCtx = document.getElementById(&#39;distChart&#39;).getContext(&#39;2d&#39;);&#xA;    distChart = new Chart(dCtx, {&#xA;        type: &#39;bar&#39;,&#xA;        data: { datasets: [] },&#xA;        options: {&#xA;            indexAxis: &#39;y&#39;,&#xA;            ...chartOptions,&#xA;            scales: {&#xA;                x: { &#xA;                    grid: { color: &#39;#f5f5f5&#39; },&#xA;                    ticks: { color: &#39;#999&#39;, font: { family: &#39;JetBrains Mono&#39;, size: 8 } },&#xA;                    title: { display: true, text: &#39;Freq&#39;, font: { size: 10 } }&#xA;                },&#xA;                y: { ...yAxisConfig, title: { display: false } }&#xA;            }&#xA;        }&#xA;    });&#xA;&#xA;    if (typeof Module === &#39;function&#39;) {&#xA;        Module().then(instance =&gt; {&#xA;            mcModule = instance;&#xA;            updateSimulation();&#xA;        });&#xA;    }&#xA;&#xA;    const rateInput = document.getElementById(&#39;rateInput&#39;);&#xA;    const volInput = document.getElementById(&#39;volInput&#39;);&#xA;    const pathInput = document.getElementById(&#39;pathInput&#39;);&#xA;    const calcButton = document.getElementById(&#39;calcButton&#39;);&#xA;&#xA;    calcButton.addEventListener(&#39;click&#39;, updateSimulation);&#xA;&#xA;    function updateSimulation() {&#xA;        if (!mcModule) return;&#xA;        &#xA;        const rate = parseFloat(rateInput.value) / 100.0;&#xA;        const vol = parseFloat(volInput.value) / 100.0;&#xA;        const numPaths = parseInt(pathInput.value) || 1;&#xA;        const spot = 100.0;&#xA;        const T = 1.0;&#xA;        &#xA;        chart.data.datasets = []; &#xA;        const baseSeed = Math.floor(Math.random() * 1000000);&#xA;        &#xA;        let allPaths = [];&#xA;        let finalPrices = [];&#xA;        let globalMin = spot;&#xA;        let globalMax = spot;&#xA;&#xA;        for (let p = 0; p &lt; numPaths; p++) {&#xA;            const seed = baseSeed + p; &#xA;            &#xA;            const rawPath = mcModule.get_sample_path(spot, rate, vol, T, 252, seed);&#xA;            const jsPath = [];&#xA;            for (let i = 0; i &lt; rawPath.size(); i++) {&#xA;                const val = rawPath.get(i);&#xA;                jsPath.push(val);&#xA;                if (val &lt; globalMin) globalMin = val;&#xA;                if (val &gt; globalMax) globalMax = val;&#xA;            }&#xA;            allPaths.push(jsPath);&#xA;            finalPrices.push(jsPath[jsPath.length - 1]);&#xA;&#xA;            chart.data.datasets.push({&#xA;                data: jsPath,&#xA;                borderColor: &#39;rgba(37, 99, 235, 0.12)&#39;,&#xA;                borderWidth: 1,&#xA;                fill: false,&#xA;                pointRadius: 0,&#xA;                order: 3 &#xA;            });&#xA;        }&#xA;&#xA;        let avgFinalPrice = 0;&#xA;        if (numPaths &gt; 0) {&#xA;            const avgPath = [];&#xA;            for (let i = 0; i &lt; 253; i++) {&#xA;                let sum = 0;&#xA;                for (let p = 0; p &lt; numPaths; p++) sum += allPaths[p][i];&#xA;                const val = sum / numPaths;&#xA;                avgPath.push(val);&#xA;                if (val &lt; globalMin) globalMin = val;&#xA;                if (val &gt; globalMax) globalMax = val;&#xA;            }&#xA;            avgFinalPrice = avgPath[avgPath.length - 1];&#xA;&#xA;            chart.data.datasets.push({&#xA;                data: avgPath,&#xA;                borderColor: &#39;#000&#39;,&#xA;                borderWidth: 2,&#xA;                fill: false,&#xA;                pointRadius: 0,&#xA;                order: 1 &#xA;            });&#xA;        }&#xA;&#xA;        const padding = (globalMax - globalMin) * 0.1;&#xA;        const yMin = globalMin - padding;&#xA;        const yMax = globalMax + padding;&#xA;&#xA;        chart.options.scales.y.min = yMin;&#xA;        chart.options.scales.y.max = yMax;&#xA;        chart.update();&#xA;&#xA;        updateDistribution(finalPrices, avgFinalPrice, spot, yMin, yMax);&#xA;&#xA;        const profitablePaths = finalPrices.filter(p =&gt; p &gt; spot).length;&#xA;        const pop = (profitablePaths / numPaths) * 100;&#xA;        document.getElementById(&#39;pop-value&#39;).innerText = pop.toFixed(1) + &#34;%&#34;;&#xA;&#xA;        try {&#xA;            const greeksCount = Math.min(Math.max(numPaths, 1000), 5000);&#xA;            const greeks = mcModule.get_greeks(&#34;european&#34;, spot, 100.0, rate, vol, T, 252, greeksCount, baseSeed);&#xA;            document.getElementById(&#39;delta-value&#39;).innerText = greeks.delta.toFixed(4);&#xA;            document.getElementById(&#39;gamma-value&#39;).innerText = greeks.gamma.toFixed(4);&#xA;            document.getElementById(&#39;vega-value&#39;).innerText = greeks.vega.toFixed(2);&#xA;            document.getElementById(&#39;theta-value&#39;).innerText = greeks.theta.toFixed(2);&#xA;            document.getElementById(&#39;rho-value&#39;).innerText = greeks.rho.toFixed(2);&#xA;        } catch (err) {&#xA;            console.error(&#34;Greeks computation failed:&#34;, err);&#xA;        }&#xA;    }&#xA;&#xA;    function updateDistribution(finalPrices, avgFinalPrice, spot, minP, maxP) {&#xA;        distChart.options.scales.y.min = minP;&#xA;        distChart.options.scales.y.max = maxP;&#xA;&#xA;        const binCount = 40; &#xA;        const binWidth = (maxP - minP) / binCount;&#xA;        const binData = [];&#xA;        for(let i=0; i&lt;binCount; i++) {&#xA;            const low = minP + i * binWidth;&#xA;            const high = low + binWidth;&#xA;            const mid = low + (binWidth / 2);&#xA;            const count = finalPrices.filter(p =&gt; p &gt;= low &amp;&amp; p &lt; high).length;&#xA;            binData.push({y: mid, x: count});&#xA;        }&#xA;&#xA;        const maxFreq = Math.max(...binData.map(d =&gt; d.x), 1);&#xA;        distChart.data.datasets = [&#xA;            {&#xA;                type: &#39;bar&#39;,&#xA;                label: &#39;Frequency&#39;,&#xA;                data: binData,&#xA;                backgroundColor: &#39;rgba(37, 99, 235, 0.5)&#39;,&#xA;                borderColor: &#39;rgba(37, 99, 235, 0.8)&#39;,&#xA;                borderWidth: 1,&#xA;                barPercentage: 1.0,&#xA;                categoryPercentage: 1.0,&#xA;                order: 3&#xA;            },&#xA;            {&#xA;                type: &#39;line&#39;,&#xA;                data: [{x: 0, y: avgFinalPrice}, {x: maxFreq * 1.5, y: avgFinalPrice}],&#xA;                borderColor: &#39;#000&#39;,&#xA;                borderWidth: 2,&#xA;                pointRadius: 0,&#xA;                fill: false,&#xA;                order: 1&#xA;            },&#xA;            {&#xA;                type: &#39;line&#39;,&#xA;                data: [{x: 0, y: spot}, {x: maxFreq * 1.5, y: spot}],&#xA;                borderColor: &#39;rgba(239, 68, 68, 0.7)&#39;,&#xA;                borderWidth: 1.5,&#xA;                borderDash: [4, 4],&#xA;                pointRadius: 0,&#xA;                fill: false,&#xA;                order: 2&#xA;            }&#xA;        ];&#xA;        distChart.update();&#xA;    }&#xA;&#xA;    const heatButton = document.getElementById(&#39;heatButton&#39;);&#xA;    heatButton.addEventListener(&#39;click&#39;, generateHeatmap);&#xA;&#xA;    function generateHeatmap() {&#xA;        if (!mcModule) return;&#xA;&#xA;        const type = document.getElementById(&#39;optType&#39;).value;&#xA;        const metric = document.getElementById(&#39;metricType&#39;).value;&#xA;        const strike = 100.0;&#xA;        const rate = parseFloat(rateInput.value) / 100.0; &#xA;        const expiry = 1.0;&#xA;        const sMin = parseFloat(document.getElementById(&#39;spotMin&#39;).value);&#xA;        const sMax = parseFloat(document.getElementById(&#39;spotMax&#39;).value);&#xA;        const vMin = parseFloat(document.getElementById(&#39;vMin&#39;).value) / 100.0;&#xA;        const vMax = parseFloat(document.getElementById(&#39;vMax&#39;).value) / 100.0;&#xA;        const steps = parseInt(document.getElementById(&#39;steps&#39;).value);&#xA;        const numSims = parseInt(document.getElementById(&#39;heatSims&#39;).value) || 1000;&#xA;&#xA;        try {&#xA;            const rawData = mcModule.get_price_heatmap(type, metric, strike, rate, expiry, sMin, sMax, steps, vMin, vMax, steps, numSims, 42);&#xA;            const data = [];&#xA;            for (let i = 0; i &lt; rawData.size(); i++) data.push(rawData.get(i));&#xA;            renderHeatmap(data, steps, sMin, sMax, vMin * 100, vMax * 100, metric.toUpperCase());&#xA;        } catch (err) {&#xA;            console.error(&#34;Heatmap generation failed:&#34;, err);&#xA;        }&#xA;    }&#xA;&#xA;    function renderHeatmap(data, steps, sMin, sMax, vMin, vMax, label) {&#xA;        const canvas = document.getElementById(&#39;heatChart&#39;);&#xA;        const ctx = canvas.getContext(&#39;2d&#39;);&#xA;        const width = canvas.width = 650; &#xA;        const height = canvas.height = 400;&#xA;        const margin = { top: 30, right: 80, bottom: 45, left: 55 };&#xA;        const plotW = width - margin.left - margin.right;&#xA;        const plotH = height - margin.top - margin.bottom;&#xA;        const cellW = plotW / steps;&#xA;        const cellH = plotH / steps;&#xA;        const maxPrice = Math.max(...data);&#xA;        const minPrice = Math.min(...data);&#xA;&#xA;        const getColor = (val) =&gt; {&#xA;            const t = (val - minPrice) / (maxPrice - minPrice || 1);&#xA;            const stops = [&#xA;                {t: 0.00, r: 68,  g: 1,   b: 84},  &#xA;                {t: 0.25, r: 59,  g: 82,  b: 139}, &#xA;                {t: 0.50, r: 33,  g: 145, b: 140}, &#xA;                {t: 0.75, r: 94,  g: 201, b: 98},  &#xA;                {t: 1.00, r: 253, g: 231, b: 37}   &#xA;            ];&#xA;            let i = 1;&#xA;            while (i &lt; stops.length - 1 &amp;&amp; t &gt; stops[i].t) i++;&#xA;            const s1 = stops[i-1], s2 = stops[i];&#xA;            const weight = (t - s1.t) / (s2.t - s1.t);&#xA;            return `rgb(${Math.floor(s1.r + (s2.r - s1.r) * weight)}, ${Math.floor(s1.g + (s2.g - s1.g) * weight)}, ${Math.floor(s1.b + (s2.b - s1.b) * weight)})`;&#xA;        };&#xA;&#xA;        ctx.clearRect(0, 0, width, height);&#xA;        for (let i = 0; i &lt; steps; i++) { &#xA;            for (let j = 0; j &lt; steps; j++) { &#xA;                const price = data[i * steps + j];&#xA;                ctx.fillStyle = getColor(price);&#xA;                ctx.fillRect(margin.left + j * cellW, margin.top + plotH - (i + 1) * cellH, cellW + 0.5, cellH + 0.5);&#xA;            }&#xA;        }&#xA;&#xA;        const barW = 15, barX = width - margin.right + 25;&#xA;        for (let i = 0; i &lt; plotH; i++) {&#xA;            const val = minPrice + (i / plotH) * (maxPrice - minPrice);&#xA;            ctx.fillStyle = getColor(val);&#xA;            ctx.fillRect(barX, margin.top + plotH - i, barW, 1);&#xA;        }&#xA;        &#xA;        ctx.fillStyle = &#34;#666&#34;;&#xA;        ctx.font = &#34;9px JetBrains Mono&#34;;&#xA;        ctx.textAlign = &#34;left&#34;;&#xA;        for (let i = 0; i &lt;= 4; i++) {&#xA;            const y = margin.top + plotH - (i / 4) * plotH;&#xA;            const val = minPrice + (i / 4) * (maxPrice - minPrice);&#xA;            let text = val.toFixed(2);&#xA;            if (label === &#34;PROB_PROFIT&#34;) text = (val * 100).toFixed(1) + &#34;%&#34;;&#xA;            ctx.fillText(text, barX + barW + 5, y + 3);&#xA;        }&#xA;        ctx.fillText(label, barX, margin.top - 8);&#xA;&#xA;        const strike = 100.0;&#xA;        if (strike &gt;= sMin &amp;&amp; strike &lt;= sMax) {&#xA;            const strikeX = margin.left + ((strike - sMin) / (sMax - sMin)) * plotW;&#xA;            ctx.strokeStyle = &#34;rgba(255, 255, 255, 0.8)&#34;;&#xA;            ctx.setLineDash([5, 5]);&#xA;            ctx.lineWidth = 1.5;&#xA;            ctx.beginPath();&#xA;            ctx.moveTo(strikeX, margin.top);&#xA;            ctx.lineTo(strikeX, margin.top + plotH);&#xA;            ctx.stroke();&#xA;            ctx.setLineDash([]);&#xA;            ctx.fillStyle = &#34;#fff&#34;;&#xA;            ctx.font = &#34;bold 9px JetBrains Mono&#34;;&#xA;            ctx.textAlign = &#34;center&#34;;&#xA;            ctx.fillText(&#34;K=100&#34;, strikeX, margin.top + 15);&#xA;        }&#xA;        &#xA;        ctx.fillStyle = &#34;#666&#34;;&#xA;        ctx.font = &#34;10px JetBrains Mono&#34;;&#xA;        ctx.textAlign = &#34;center&#34;;&#xA;        for (let j = 0; j &lt;= 5; j++) {&#xA;            const x = margin.left + (j / 5) * plotW;&#xA;            const val = sMin + (j / 5) * (sMax - sMin);&#xA;            ctx.fillText(val.toFixed(0), x, margin.top + plotH + 20);&#xA;        }&#xA;        ctx.textAlign = &#34;right&#34;;&#xA;        for (let i = 0; i &lt;= 5; i++) {&#xA;            const y = margin.top + plotH - (i / 5) * plotH;&#xA;            const val = vMin + (i / 5) * (vMax - vMin);&#xA;            ctx.fillText(val.toFixed(0) + &#34;%&#34;, margin.left - 8, y + 4);&#xA;        }&#xA;&#xA;        ctx.fillStyle = &#34;#999&#34;;&#xA;        ctx.font = &#34;bold 9px JetBrains Mono&#34;;&#xA;        ctx.textAlign = &#34;left&#34;;&#xA;        ctx.fillText(&#34;VOLATILITY σ ↑&#34;, margin.left, margin.top - 10);&#xA;        ctx.textAlign = &#34;right&#34;;&#xA;        ctx.fillText(&#34;ASSET PRICE S →&#34;, margin.left + plotW, margin.top + plotH + 35);&#xA;&#xA;        ctx.strokeStyle = &#34;#eee&#34;;&#xA;        ctx.strokeRect(margin.left, margin.top, plotW, plotH);&#xA;    }&#xA;&lt;/script&gt;</description>
