    <item>
      <title>Monte Carlo Simulation</title>
      <link>//localhost:1313/projects/monte-carlo/</link>
      <pubDate>Tue, 31 Mar 2026 00:00:00 +0000</pubDate>
      <guid>//localhost:1313/projects/monte-carlo/</guid>
      <description>&lt;p&gt;This project demonstrates a high-performance Monte Carlo simulation for Geometric Brownian Motion, implemented in C++ and compiled to WebAssembly.&lt;/p&gt;&#xA;&lt;div class=&#34;mc-widget&#34;&gt;&#xA;    &lt;div style=&#34;display: flex; gap: 20px; align-items: flex-end; margin-bottom: 30px; flex-wrap: wrap;&#34;&gt;&#xA;        &lt;div style=&#34;flex: 1; min-width: 150px;&#34;&gt;&#xA;            &lt;label style=&#34;display: block; font-family: &#39;JetBrains Mono&#39;, monospace; font-size: 0.7rem; color: var(--muted); margin-bottom: 8px;&#34;&gt;VOLATILITY (%)&lt;/label&gt;&#xA;            &lt;input type=&#34;number&#34; id=&#34;volInput&#34; value=&#34;20&#34; min=&#34;1&#34; max=&#34;500&#34; step=&#34;0.5&#34; &#xA;                   style=&#34;width: 100%; padding: 8px; border: 1px solid var(--border); border-radius: 4px; font-family: &#39;JetBrains Mono&#39;, monospace;&#34;&gt;&#xA;        &lt;/div&gt;&#xA;        &lt;div style=&#34;flex: 1; min-width: 150px;&#34;&gt;&#xA;            &lt;label style=&#34;display: block; font-family: &#39;JetBrains Mono&#39;, monospace; font-size: 0.7rem; color: var(--muted); margin-bottom: 8px;&#34;&gt;NUMBER OF PATHS&lt;/label&gt;&#xA;            &lt;input type=&#34;number&#34; id=&#34;pathInput&#34; value=&#34;250&#34; min=&#34;1&#34; max=&#34;5000&#34; &#xA;                   style=&#34;width: 100%; padding: 8px; border: 1px solid var(--border); border-radius: 4px; font-family: &#39;JetBrains Mono&#39;, monospace;&#34;&gt;&#xA;        &lt;/div&gt;&#xA;        &lt;div style=&#34;flex: 0;&#34;&gt;&#xA;            &lt;button id=&#34;calcButton&#34; &#xA;                    style=&#34;padding: 9px 24px; background: var(--accent); color: #fff; border: none; border-radius: 4px; font-family: &#39;Inter&#39;, sans-serif; font-weight: 600; cursor: pointer; height: 40px;&#34;&gt;&#xA;                Calculate&#xA;            &lt;/button&gt;&#xA;        &lt;/div&gt;&#xA;    &lt;/div&gt;&#xA;&#xA;    &lt;div style=&#34;display: flex; gap: 0; height: 450px; width: 100%; margin-bottom: 20px; background: #fff; border: 1px solid var(--border); border-radius: 8px; overflow: hidden;&#34;&gt;&#xA;        &lt;div style=&#34;flex: 4; position: relative;&#34;&gt;&#xA;            &lt;canvas id=&#34;mcChart&#34;&gt;&lt;/canvas&gt;&#xA;        &lt;/div&gt;&#xA;        &lt;div style=&#34;flex: 1; position: relative; border-left: 1px solid #f0f0f0;&#34;&gt;&#xA;            &lt;canvas id=&#34;distChart&#34;&gt;&lt;/canvas&gt;&#xA;        &lt;/div&gt;&#xA;    &lt;/div&gt;&#xA;&#xA;    &#xA;    &lt;div style=&#34;display: grid; grid-template-columns: repeat(5, 1fr); gap: 10px; margin-top: 30px;&#34; id=&#34;greeks-container&#34;&gt;&#xA;        &lt;div style=&#34;padding: 10px; border: 1px solid var(--border); border-radius: 8px; text-align: center;&#34;&gt;&#xA;            &lt;div style=&#34;font-family: &#39;JetBrains Mono&#39;, monospace; font-size: 0.65rem; color: var(--muted); margin-bottom: 4px;&#34;&gt;DELTA&lt;/div&gt;&#xA;            &lt;div style=&#34;font-family: &#39;JetBrains Mono&#39;, monospace; font-weight: 600; font-size: 0.9rem;&#34; id=&#34;delta-value&#34;&gt;0.0000&lt;/div&gt;&#xA;        &lt;/div&gt;&#xA;        &lt;div style=&#34;padding: 10px; border: 1px solid var(--border); border-radius: 8px; text-align: center;&#34;&gt;&#xA;            &lt;div style=&#34;font-family: &#39;JetBrains Mono&#39;, monospace; font-size: 0.65rem; color: var(--muted); margin-bottom: 4px;&#34;&gt;GAMMA&lt;/div&gt;&#xA;            &lt;div style=&#34;font-family: &#39;JetBrains Mono&#39;, monospace; font-weight: 600; font-size: 0.9rem;&#34; id=&#34;gamma-value&#34;&gt;0.0000&lt;/div&gt;&#xA;        &lt;/div&gt;&#xA;        &lt;div style=&#34;padding: 10px; border: 1px solid var(--border); border-radius: 8px; text-align: center;&#34;&gt;&#xA;            &lt;div style=&#34;font-family: &#39;JetBrains Mono&#39;, monospace; font-size: 0.65rem; color: var(--muted); margin-bottom: 4px;&#34;&gt;VEGA&lt;/div&gt;&#xA;            &lt;div style=&#34;font-family: &#39;JetBrains Mono&#39;, monospace; font-weight: 600; font-size: 0.9rem;&#34; id=&#34;vega-value&#34;&gt;0.0000&lt;/div&gt;&#xA;        &lt;/div&gt;&#xA;        &lt;div style=&#34;padding: 10px; border: 1px solid var(--border); border-radius: 8px; text-align: center;&#34;&gt;&#xA;            &lt;div style=&#34;font-family: &#39;JetBrains Mono&#39;, monospace; font-size: 0.65rem; color: var(--muted); margin-bottom: 4px;&#34;&gt;THETA&lt;/div&gt;&#xA;            &lt;div style=&#34;font-family: &#39;JetBrains Mono&#39;, monospace; font-weight: 600; font-size: 0.9rem;&#34; id=&#34;theta-value&#34;&gt;0.0000&lt;/div&gt;&#xA;        &lt;/div&gt;&#xA;        &lt;div style=&#34;padding: 10px; border: 1px solid var(--border); border-radius: 8px; text-align: center;&#34;&gt;&#xA;            &lt;div style=&#34;font-family: &#39;JetBrains Mono&#39;, monospace; font-size: 0.65rem; color: var(--muted); margin-bottom: 4px;&#34;&gt;RHO&lt;/div&gt;&#xA;            &lt;div style=&#34;font-family: &#39;JetBrains Mono&#39;, monospace; font-weight: 600; font-size: 0.9rem;&#34; id=&#34;rho-value&#34;&gt;0.0000&lt;/div&gt;&#xA;        &lt;/div&gt;&#xA;    &lt;/div&gt;&#xA;&lt;/div&gt;&#xA;&#xA;&lt;script src=&#34;https://cdn.jsdelivr.net/npm/chart.js&#34;&gt;&lt;/script&gt;&#xA;&lt;script src=&#34;//localhost:1313/js/mc_engine.js&#34;&gt;&lt;/script&gt;&#xA;&#xA;&lt;script&gt;&#xA;    let mcModule;&#xA;    let chart;&#xA;    let distChart;&#xA;&#xA;    const FIXED_Y_WIDTH = 45;&#xA;    const FIXED_X_HEIGHT = 25;&#xA;&#xA;    const ctx = document.getElementById(&#39;mcChart&#39;).getContext(&#39;2d&#39;);&#xA;    chart = new Chart(ctx, {&#xA;        type: &#39;line&#39;,&#xA;        data: { labels: Array.from({length: 253}, (_, i) =&gt; i), datasets: [] },&#xA;        options: {&#xA;            responsive: true,&#xA;            maintainAspectRatio: false,&#xA;            layout: { padding: 0 },&#xA;            elements: { point: { radius: 0 }, line: { tension: 0.1 } },&#xA;            scales: {&#xA;                y: { &#xA;                    type: &#39;linear&#39;,&#xA;                    grid: { color: &#39;#f0f0f0&#39;, drawBorder: false },&#xA;                    ticks: { color: &#39;#999&#39;, font: { family: &#39;JetBrains Mono&#39;, size: 9 } },&#xA;                    afterFit: (scale) =&gt; { scale.width = FIXED_Y_WIDTH; }&#xA;                },&#xA;                x: { &#xA;                    grid: { color: &#39;#f0f0f0&#39;, drawBorder: false },&#xA;                    ticks: { color: &#39;#999&#39;, font: { family: &#39;JetBrains Mono&#39;, size: 9 } },&#xA;                    afterFit: (scale) =&gt; { scale.height = FIXED_X_HEIGHT; }&#xA;                }&#xA;            },&#xA;            plugins: { legend: { display: false } },&#xA;            animation: false&#xA;        }&#xA;    });&#xA;&#xA;    const dCtx = document.getElementById(&#39;distChart&#39;).getContext(&#39;2d&#39;);&#xA;    distChart = new Chart(dCtx, {&#xA;        type: &#39;bar&#39;,&#xA;        data: { datasets: [] },&#xA;        options: {&#xA;            indexAxis: &#39;y&#39;,&#xA;            responsive: true,&#xA;            maintainAspectRatio: false,&#xA;            layout: { padding: 0 },&#xA;            scales: {&#xA;                x: { &#xA;                    grid: { display: false },&#xA;                    ticks: { display: false },&#xA;                    afterFit: (scale) =&gt; { scale.height = FIXED_X_HEIGHT; }&#xA;                },&#xA;                y: { &#xA;                    type: &#39;linear&#39;,&#xA;                    display: true,&#xA;                    position: &#39;right&#39;, &#xA;                    grid: { display: false },&#xA;                    ticks: { display: false },&#xA;                    afterFit: (scale) =&gt; { scale.width = 0; }&#xA;                }&#xA;            },&#xA;            plugins: { legend: { display: false } },&#xA;            animation: false&#xA;        }&#xA;    });&#xA;&#xA;    if (typeof Module === &#39;function&#39;) {&#xA;        Module().then(instance =&gt; {&#xA;            mcModule = instance;&#xA;            updateSimulation();&#xA;        });&#xA;    }&#xA;&#xA;    const volInput = document.getElementById(&#39;volInput&#39;);&#xA;    const pathInput = document.getElementById(&#39;pathInput&#39;);&#xA;    const calcButton = document.getElementById(&#39;calcButton&#39;);&#xA;&#xA;    calcButton.addEventListener(&#39;click&#39;, updateSimulation);&#xA;&#xA;    function updateSimulation() {&#xA;        if (!mcModule) return;&#xA;        &#xA;        const vol = parseFloat(volInput.value) / 100.0;&#xA;        const numPaths = parseInt(pathInput.value) || 1;&#xA;        const spot = 100.0;&#xA;        const drift = 0.05;&#xA;        const T = 1.0;&#xA;        &#xA;        chart.data.datasets = []; &#xA;        const baseSeed = Math.floor(Math.random() * 1000000);&#xA;        &#xA;        let allPaths = [];&#xA;        let finalPrices = [];&#xA;        let globalMin = spot;&#xA;        let globalMax = spot;&#xA;&#xA;        for (let p = 0; p &lt; numPaths; p++) {&#xA;            const seed = baseSeed + p; &#xA;            const rawPath = mcModule.get_sample_path(spot, drift, vol, T, 252, seed);&#xA;            const jsPath = [];&#xA;            for (let i = 0; i &lt; rawPath.size(); i++) {&#xA;                const val = rawPath.get(i);&#xA;                jsPath.push(val);&#xA;                if (val &lt; globalMin) globalMin = val;&#xA;                if (val &gt; globalMax) globalMax = val;&#xA;            }&#xA;            allPaths.push(jsPath);&#xA;            finalPrices.push(jsPath[jsPath.length - 1]);&#xA;&#xA;            chart.data.datasets.push({&#xA;                data: jsPath,&#xA;                borderColor: &#39;rgba(37, 99, 235, 0.12)&#39;,&#xA;                borderWidth: 1,&#xA;                fill: false,&#xA;                pointRadius: 0,&#xA;                order: 3 &#xA;            });&#xA;        }&#xA;&#xA;        let avgFinalPrice = 0;&#xA;        if (numPaths &gt; 0) {&#xA;            const avgPath = [];&#xA;            for (let i = 0; i &lt; 253; i++) {&#xA;                let sum = 0;&#xA;                for (let p = 0; p &lt; numPaths; p++) sum += allPaths[p][i];&#xA;                const val = sum / numPaths;&#xA;                avgPath.push(val);&#xA;                if (val &lt; globalMin) globalMin = val;&#xA;                if (val &gt; globalMax) globalMax = val;&#xA;            }&#xA;            avgFinalPrice = avgPath[avgPath.length - 1];&#xA;&#xA;            chart.data.datasets.push({&#xA;                data: avgPath,&#xA;                borderColor: &#39;#000&#39;,&#xA;                borderWidth: 2,&#xA;                fill: false,&#xA;                pointRadius: 0,&#xA;                order: 1 &#xA;            });&#xA;        }&#xA;&#xA;        const padding = (globalMax - globalMin) * 0.05;&#xA;        const yMin = globalMin - padding;&#xA;        const yMax = globalMax + padding;&#xA;&#xA;        chart.options.scales.y.min = yMin;&#xA;        chart.options.scales.y.max = yMax;&#xA;        chart.update();&#xA;&#xA;        updateDistribution(finalPrices, avgFinalPrice, spot, yMin, yMax);&#xA;&#xA;        try {&#xA;            const greeks = mcModule.get_greeks(&#34;european&#34;, spot, 100.0, drift, vol, T, 252, 1000, 42);&#xA;            document.getElementById(&#39;delta-value&#39;).innerText = greeks.delta.toFixed(4);&#xA;            document.getElementById(&#39;gamma-value&#39;).innerText = greeks.gamma.toFixed(4);&#xA;            document.getElementById(&#39;vega-value&#39;).innerText = greeks.vega.toFixed(2);&#xA;            document.getElementById(&#39;theta-value&#39;).innerText = greeks.theta.toFixed(2);&#xA;            document.getElementById(&#39;rho-value&#39;).innerText = greeks.rho.toFixed(2);&#xA;        } catch (err) {&#xA;            console.error(&#34;Greeks computation failed:&#34;, err);&#xA;        }&#xA;    }&#xA;&#xA;    function updateDistribution(finalPrices, avgFinalPrice, spot, minP, maxP) {&#xA;        distChart.options.scales.y.min = minP;&#xA;        distChart.options.scales.y.max = maxP;&#xA;&#xA;        const binCount = 50; &#xA;        const binWidth = (maxP - minP) / binCount;&#xA;        const binData = [];&#xA;        &#xA;        for(let i=0; i&lt;binCount; i++) {&#xA;            const low = minP + i * binWidth;&#xA;            const high = low + binWidth;&#xA;            const mid = low + (binWidth / 2);&#xA;            const count = finalPrices.filter(p =&gt; p &gt;= low &amp;&amp; p &lt; high).length;&#xA;            binData.push({y: mid, x: count});&#xA;        }&#xA;&#xA;        const maxFreq = Math.max(...binData.map(d =&gt; d.x), 1);&#xA;&#xA;        distChart.data.datasets = [&#xA;            {&#xA;                type: &#39;bar&#39;,&#xA;                data: binData,&#xA;                backgroundColor: &#39;rgba(37, 99, 235, 0.5)&#39;,&#xA;                borderColor: &#39;rgba(37, 99, 235, 0.8)&#39;,&#xA;                borderWidth: 1,&#xA;                barPercentage: 1.0,&#xA;                categoryPercentage: 1.0,&#xA;                order: 3&#xA;            },&#xA;            {&#xA;                type: &#39;line&#39;,&#xA;                data: [{x: 0, y: avgFinalPrice}, {x: maxFreq * 2, y: avgFinalPrice}],&#xA;                borderColor: &#39;#000&#39;,&#xA;                borderWidth: 2,&#xA;                pointRadius: 0,&#xA;                fill: false,&#xA;                order: 1&#xA;            },&#xA;            {&#xA;                type: &#39;line&#39;,&#xA;                data: [{x: 0, y: spot}, {x: maxFreq * 2, y: spot}],&#xA;                borderColor: &#39;rgba(239, 68, 68, 0.7)&#39;,&#xA;                borderWidth: 1.5,&#xA;                borderDash: [4, 4],&#xA;                pointRadius: 0,&#xA;                fill: false,&#xA;                order: 2&#xA;            }&#xA;        ];&#xA;&#xA;        distChart.update();&#xA;    }&#xA;&lt;/script&gt;</description>
